# Public, non-secret identity contract for self-signed Agent Visor releases.
# The SHA-1 value is the certificate identity shown by `security find-identity`.
AGENT_VISOR_RELEASE_IDENTITY="AgentVisor Release"
AGENT_VISOR_RELEASE_CERT_SHA1="8CED2C628C9DD2752EB62B1D6CE48CC1E6426BC7"

# One-time migration boundary from the 2.4.6 updater that re-signs replacements.
AGENT_VISOR_ADHOC_BRIDGE_VERSION="2.4.7"
AGENT_VISOR_ADHOC_BRIDGE_BUILD="48"
AGENT_VISOR_STABLE_MINIMUM_UPDATE_BUILD="48"
